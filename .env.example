# ── Site ──────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://naazware.com

# ── Sanity (CMS / admin at /studio) ───────────────────
# Project ID is safe to expose; get it from sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-06-01
# Editor token (server only) — used to save contact submissions + seed content.
# Create at sanity.io/manage → API → Tokens (Editor). KEEP SECRET.
SANITY_API_WRITE_TOKEN=

# ── Email (contact-form notifications via Resend) ─────
# Get an API key at resend.com → API Keys. KEEP SECRET.
RESEND_API_KEY=
CONTACT_NOTIFICATION_TO=naazware@gmail.com
# Until you verify your own domain in Resend, the test sender below works:
RESEND_FROM=Naazware <onboarding@resend.dev>
